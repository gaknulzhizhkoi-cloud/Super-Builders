#!/system/bin/sh

PATH=/data/adb/ksu/bin:/data/adb/magisk:/system/bin:/system/xbin:/vendor/bin:$PATH

STATE_DIR=/data/adb/resukisu-stealth
GEN_DIR="$STATE_DIR/generated"
RULES_DIR="$STATE_DIR/rules.d"
LOG_FILE="$STATE_DIR/resukisu-stealth.log"
MODULES_DIR=/data/adb/modules
MODULES_UPDATE_DIR=/data/adb/modules_update

KNOWN_PATTERN='brene|brewheel|brezygisk|rezygisk|zygisk|lsposed|relsposed|teesimulator|rstee|ta_enhanced|tricky'

log() {
  mkdir -p "$STATE_DIR" 2>/dev/null || true
  printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null)" "$*" >> "$LOG_FILE" 2>/dev/null || true
}

say() {
  printf '%s\n' "$*"
  log "$*"
}

ensure_dirs() {
  mkdir -p "$GEN_DIR" "$RULES_DIR" 2>/dev/null || true
}

strip_comments() {
  sed 's/[[:space:]]#.*$//' "$1" 2>/dev/null | sed '/^[[:space:]]*$/d'
}

add_unique() {
  file="$1"
  value="$2"
  [ -n "$value" ] || return 0
  touch "$file" 2>/dev/null || return 0
  grep -Fqx "$value" "$file" 2>/dev/null || printf '%s\n' "$value" >> "$file"
}

find_susfs_bin() {
  for bin in /data/adb/ksu/bin/ksu_susfs /data/adb/ksu/bin/susfs /data/adb/ksu/bin/ksu_susfs_arm64; do
    [ -x "$bin" ] && { printf '%s\n' "$bin"; return 0; }
  done
  return 1
}

find_brene_dir() {
  for base in "$MODULES_DIR" "$MODULES_UPDATE_DIR"; do
    [ -d "$base" ] || continue
    for dir in "$base"/*; do
      [ -d "$dir" ] || continue
      prop="$dir/module.prop"
      text="$(basename "$dir")"
      [ -f "$prop" ] && text="$text $(cat "$prop" 2>/dev/null)"
      printf '%s\n' "$text" | grep -Eiq '(^|[^a-z])brene([^a-z]|$)' && { printf '%s\n' "$dir"; return 0; }
    done
  done
  return 1
}

module_is_known() {
  dir="$1"
  prop="$dir/module.prop"
  text="$(basename "$dir")"
  [ -f "$prop" ] && text="$text $(cat "$prop" 2>/dev/null)"
  printf '%s\n' "$text" | grep -Eiq "$KNOWN_PATTERN"
}

emit_kstat_json() {
  src="$1"
  out="$GEN_DIR/sus_kstat_statically.json"
  {
    printf '{\n'
    printf '  "generated_by": "resukisu-stealth-policy",\n'
    printf '  "paths": [\n'
    first=1
    strip_comments "$src" | awk '{print $1}' | sort -u | while IFS= read -r path; do
      [ -n "$path" ] || continue
      esc=$(printf '%s' "$path" | sed 's/\\/\\\\/g; s/"/\\"/g')
      if [ "$first" = 1 ]; then
        printf '    "%s"' "$esc"
        first=0
      else
        printf ',\n    "%s"' "$esc"
      fi
    done
    printf '\n  ]\n}\n'
  } > "$out"
}

scan_module_dir() {
  dir="$1"
  [ -d "$dir" ] || return 0
  module_is_known "$dir" || return 0

  real="$dir"
  realpath_bin=$(command -v readlink 2>/dev/null)
  [ -n "$realpath_bin" ] && real=$(readlink -f "$dir" 2>/dev/null || printf '%s' "$dir")

  add_unique "$GEN_DIR/sus_path.txt" "$real 15"
  add_unique "$GEN_DIR/sus_path_loop.txt" "$real 15"
  add_unique "$GEN_DIR/sus_mount.txt" "$real"
  add_unique "$GEN_DIR/sus_kstat.txt" "$real"

  find "$dir" -type f \( -name '*.so' -o -name '*.dex' -o -name '*.jar' -o -name '*.apk' -o -name '*zygisk*' -o -name '*lsposed*' -o -name '*relsposed*' -o -name '*daemon*' -o -name '*service*' -o -name '*tee*' -o -name '*tricky*' \) 2>/dev/null |
    while IFS= read -r file; do
      real_file="$file"
      [ -n "$realpath_bin" ] && real_file=$(readlink -f "$file" 2>/dev/null || printf '%s' "$file")
      add_unique "$GEN_DIR/sus_maps.txt" "$real_file"
      add_unique "$GEN_DIR/sus_path.txt" "$real_file 15"
      add_unique "$GEN_DIR/sus_kstat.txt" "$real_file"
    done

  find "$dir" -type f -perm /111 2>/dev/null |
    while IFS= read -r file; do
      real_file="$file"
      [ -n "$realpath_bin" ] && real_file=$(readlink -f "$file" 2>/dev/null || printf '%s' "$file")
      add_unique "$GEN_DIR/sus_maps.txt" "$real_file"
      add_unique "$GEN_DIR/sus_kstat.txt" "$real_file"
    done
}

cmd_rescan() {
  ensure_dirs
  for name in sus_maps.txt sus_mount.txt sus_path.txt sus_path_loop.txt sus_open_redirect.txt sus_kstat.txt; do
    printf '# generated by resukisu-stealth-policy\n' > "$GEN_DIR/$name"
  done

  for base in "$MODULES_DIR" "$MODULES_UPDATE_DIR"; do
    [ -d "$base" ] || continue
    for dir in "$base"/*; do
      scan_module_dir "$dir"
    done
  done

  # KernelSU/ReSukiSU shared roots can leak through module bind mounts and helper paths.
  for root in /data/adb/ksu /data/adb/modules /data/adb/modules_update; do
    [ -e "$root" ] || continue
    add_unique "$GEN_DIR/sus_path.txt" "$root 15"
    add_unique "$GEN_DIR/sus_mount.txt" "$root"
    add_unique "$GEN_DIR/sus_kstat.txt" "$root"
  done

  emit_kstat_json "$GEN_DIR/sus_kstat.txt"
  cmd_export_brene >/dev/null 2>&1 || true
  say "rescan complete: $(grep -chv '^#' "$GEN_DIR"/sus_*.txt 2>/dev/null | awk '{s+=$1} END{print s+0}') text rules"
}

apply_list() {
  file="$1"
  command_name="$2"
  shift 2
  bin="$1"
  [ -f "$file" ] || return 0
  strip_comments "$file" | while IFS= read -r line; do
    set -- $line
    [ -n "$1" ] || continue
    "$bin" "$command_name" "$@" >/dev/null 2>&1 || log "skip unsupported or failed: $command_name $line"
  done
}

apply_local_conf() {
  bin="$1"
  conf="$STATE_DIR/local.conf"
  [ -f "$conf" ] || return 0
  strip_comments "$conf" | while IFS= read -r line; do
    set -- $line
    cmd="$1"
    shift || true
    case "$cmd" in
      sus_path) "$bin" add_sus_path "$@" >/dev/null 2>&1 || log "local failed: $line" ;;
      sus_path_loop) "$bin" add_sus_path_loop "$@" >/dev/null 2>&1 || log "local failed: $line" ;;
      sus_mount) "$bin" add_sus_mount "$@" >/dev/null 2>&1 || log "local failed: $line" ;;
      sus_map) "$bin" add_sus_map "$@" >/dev/null 2>&1 || log "local failed: $line" ;;
      sus_kstat) "$bin" add_sus_kstat "$@" >/dev/null 2>&1 || log "local failed: $line" ;;
      open_redirect) "$bin" add_open_redirect "$@" >/dev/null 2>&1 || log "local failed: $line" ;;
    esac
  done
}

cmd_apply() {
  ensure_dirs
  [ -f "$GEN_DIR/sus_path.txt" ] || cmd_rescan >/dev/null 2>&1 || true
  bin=$(find_susfs_bin) || { say "ksu_susfs not found; install/enable BRENE first"; return 1; }

  for dir in "$GEN_DIR" "$RULES_DIR"; do
    apply_list "$dir/sus_path.txt" add_sus_path "$bin"
    apply_list "$dir/sus_path_loop.txt" add_sus_path_loop "$bin"
    apply_list "$dir/sus_mount.txt" add_sus_mount "$bin"
    apply_list "$dir/sus_maps.txt" add_sus_map "$bin"
    apply_list "$dir/sus_kstat.txt" add_sus_kstat "$bin"
    apply_list "$dir/sus_open_redirect.txt" add_open_redirect "$bin"
  done
  apply_local_conf "$bin"

  "$bin" hide_sus_mnts_for_all_or_non_su_procs 1 >/dev/null 2>&1 || true
  "$bin" hide_sus_mnts_for_non_su_procs 1 >/dev/null 2>&1 || true
  say "apply complete via $bin"
}

cmd_status() {
  ensure_dirs
  printf 'state_dir=%s\n' "$STATE_DIR"
  if brene=$(find_brene_dir); then
    printf 'brene=detected:%s\n' "$brene"
  else
    printf 'brene=not_detected\n'
  fi
  if bin=$(find_susfs_bin); then
    printf 'ksu_susfs=%s\n' "$bin"
    "$bin" show enabled_features 2>/dev/null || true
    "$bin" show version 2>/dev/null || true
  else
    printf 'ksu_susfs=missing\n'
  fi
  for file in "$GEN_DIR"/sus_*.txt "$RULES_DIR"/sus_*.txt; do
    [ -f "$file" ] || continue
    printf '%s=%s\n' "$(basename "$file")" "$(strip_comments "$file" | wc -l 2>/dev/null | tr -d ' ')"
  done
}

cmd_export_brene() {
  ensure_dirs
  brene=$(find_brene_dir) || return 1
  for name in sus_maps.txt sus_mount.txt sus_path.txt sus_path_loop.txt sus_open_redirect.txt sus_kstat_statically.json; do
    [ -f "$GEN_DIR/$name" ] && cp -af "$GEN_DIR/$name" "$brene/$name" 2>/dev/null || true
  done
  say "exported generated rules to $brene"
}

cmd_reset() {
  rm -rf "$GEN_DIR" 2>/dev/null || true
  mkdir -p "$GEN_DIR" 2>/dev/null || true
  say "generated rules reset; local.conf and rules.d kept"
}

case "$1" in
  rescan) cmd_rescan ;;
  apply) cmd_apply ;;
  status|"") cmd_status ;;
  export-brene) cmd_export_brene ;;
  reset) cmd_reset ;;
  *)
    cat <<EOF
Usage: resukisu-stealth <command>

Commands:
  rescan        scan known module dirs and regenerate SUSFS rule files
  apply         apply generated and local rules through ksu_susfs
  status        print BRENE/ksu_susfs status and rule counts
  export-brene  copy generated rule files into the BRENE module directory
  reset         clear generated rules, keeping local overrides
EOF
    exit 2
    ;;
esac
